# ============================================
# 🌐 Configuration générale de l'application
# ============================================

# Port d'écoute du serveur Fastify
PORT=5000

# Environnement : development | production
NODE_ENV=development


# ============================================
# 🔐 Sécurité & Authentification
# ============================================

# Clé secrète pour signer les tokens JWT
JWT_SECRET=change_me_please

# Durée de validité des tokens (ex: "1h", "7d")
JWT_EXPIRES_IN=1h


# ============================================
# 🗄️ Base de données (si utilisée)
# ============================================

# Exemple pour PostgreSQL
DATABASE_URL=postgres://user:password@localhost:5432/exapi

# Exemple pour SQLite (si tu veux un mode simple)
# DATABASE_URL=file:./exapi.db


# ============================================
# 📨 Services externes (optionnel)
# ============================================

# URL d'une API externe si ExAPI doit consommer un service
EXTERNAL_API_URL=https://api.example.com

# Clé API externe
EXTERNAL_API_KEY=your_api_key_here


# ============================================
# 🧪 Tests & Développement
# ============================================

# Active le mode debug Fastify
DEBUG=false

# Active les logs détaillés
LOG_LEVEL=info
