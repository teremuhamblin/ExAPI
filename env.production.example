# ============================================
# 🌐 Production
# ============================================

PORT=5000
NODE_ENV=production


# ============================================
# 🔐 Sécurité
# ============================================

JWT_SECRET=REPLACE_WITH_A_LONG_SECURE_KEY
JWT_EXPIRES_IN=1h


# ============================================
# 🗄️ Base de données (PostgreSQL en production)
# ============================================

DATABASE_URL=postgres://exapi:password@db:5432/exapi


# ============================================
# 📨 Services externes
# ============================================

EXTERNAL_API_URL=https://api.example.com
EXTERNAL_API_KEY=REPLACE_ME


# ============================================
# 🧪 Logs
# ============================================

LOG_LEVEL=warn
DEBUG=false


# ============================================
# ❤️ Healthcheck
# ============================================

HEALTHCHECK_PATH=/health
