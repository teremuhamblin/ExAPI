# ============================================
# 🌐 Développement
# ============================================

PORT=5000
NODE_ENV=development


# ============================================
# 🔐 Auth
# ============================================

JWT_SECRET=dev_secret_key
JWT_EXPIRES_IN=1h


# ============================================
# 🗄️ Base de données (SQLite pour dev)
# ============================================

DATABASE_URL=file:./exapi.db


# ============================================
# 📨 Services externes (mock)
# ============================================

EXTERNAL_API_URL=http://localhost:9999/mock
EXTERNAL_API_KEY=dev_key


# ============================================
# 🧪 Logs
# ============================================

LOG_LEVEL=debug
DEBUG=true


# ============================================
# ❤️ Healthcheck
# ============================================

HEALTHCHECK_PATH=/health
