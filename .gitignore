# ============================
# ExAPI — .gitignore officiel
# ============================

# --- Node / Bun ---
node_modules/
bun.lockb
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Build output ---
dist/
build/
.cache/

# --- TypeScript ---
*.tsbuildinfo

# --- Environment files ---
.env
.env.*
!.env.example
!.env.development.example
!.env.production.example

# --- Logs ---
logs/
*.log
*.log.*
debug.log
error.log

# --- Coverage ---
coverage/
*.lcov

# --- OS files ---
.DS_Store
Thumbs.db

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- Docker ---
docker-data/
docker-compose.override.yml

# --- Temporary files ---
tmp/
temp/
*.tmp

# --- Fastify ---
.fastify*

# --- Tests ---
jest-cache/
jest-temp/
